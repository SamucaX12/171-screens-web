# =============================================================================
# Deep Screen Share — variáveis de ambiente (Vercel / produção)
# Copie para Vercel → Settings → Environment Variables
# Local: copie para .env.local (NUNCA commite .env.local)
# =============================================================================

# URL pública do site (sem barra no final)
# Produção: https://deepscreenshare.vercel.app
# Local:    http://localhost:3007
NEXT_PUBLIC_APP_URL=https://deepscreenshare.vercel.app

# Segredo JWT — mínimo 32 caracteres (gere: openssl rand -base64 32)
AUTH_SECRET=

# MongoDB Atlas — mesma cluster do scanner
# Bancos automáticos: deepscreendb (curso) + 171screens (scanner)
MONGODB_URI=

# --- Discord OAuth (login + sync de cargo) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=1519239094297821304
DISCORD_BOT_TOKEN=
DISCORD_INVITE_URL=https://discord.gg/CXkyv3QF9X

# Cargos do curso no Discord (Deep Screen Share)
DISCORD_ROLE_TIER1_ID=1519239094322991146
DISCORD_ROLE_TIER2_ID=1519239094322991148
DISCORD_ROLE_TIER3_ID=1519239094322991149
DISCORD_ROLE_BOOSTER_ID=1519239094339633202

# Cargos Curso Mobile
DISCORD_ROLE_IOS_ID=1519239094322991145
DISCORD_ROLE_ANDROID_ID=1519239094322991144

# Discord IDs dos owners (separados por vírgula)
OWNER_DISCORD_IDS=

# --- Scanner install zip (opcional) ---
# Caminho absoluto do .exe no servidor (VPS). Na Vercel use public/scanner/171-screens.exe
# SCANNER_EXE_PATH=

# DISCORD_TICKET_CATEGORY_ID=
# DISCORD_TICKET_STAFF_ROLE_ID=

# --- Tutor IA do curso (opcional — sem key usa busca no conteúdo) ---
# OpenAI, Groq, etc. (compatível OpenAI API)
# COURSE_AI_API_KEY=
# COURSE_AI_BASE_URL=https://api.openai.com/v1
# COURSE_AI_MODEL=gpt-4o-mini

# --- Google OAuth (desativado no site — em breve) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
